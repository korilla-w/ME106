<screen>

    <animations>
        <timeline name="factory_dialog_open">
            <animation target="factory_dialog" prop="opa" start="0" end="255" duration="120" early_apply="true"/>
            <animation target="factory_dialog" prop="translate_y" start="6" end="0" duration="120" early_apply="true"/>
        </timeline>
    </animations>

    <view width="320" height="240">
        <style name="me106_fill_black"/>
        <bind_style name="me106_theme_light_screen_bg" subject="meter_theme_index" ref_value="1"/>
        <bind_style name="me106_theme_alarm_screen_bg" subject="meter_theme_index" ref_value="2"/>


        <play_timeline_event target="self" timeline="factory_dialog_open" trigger="screen_loaded"/>
        <subject_set_int_event subject="meter_factory_confirm_index" value="0" trigger="screen_loaded"/>
        <subject_set_int_event subject="meter_factory_reset_request" value="0" trigger="screen_loaded"/>

        <!-- UI 层弹窗：只发出恢复设置请求，不直接擦除 NVS、升级固件或复位硬件。 -->
        <lv_obj name="factory_modal_layer" x="0" y="0" width="320" height="207" style_bg_color="0x000000" style_bg_opa="190" style_border_width="0" style_pad_all="0" scrollable="false"/>

        <lv_obj name="factory_dialog" x="30" y="36" width="260" height="150" style_bg_color="0x242424" style_bg_opa="255" style_border_width="1" style_border_color="0x303030" style_border_opa="255" style_radius="8" style_pad_all="0" scrollable="false">



            <lv_label text="&#x6062;&#x590D;&#x51FA;&#x5382;&#x8BBE;&#x7F6E;&#xFF1F;" x="18" y="16" width="224">
                <style name="me106_text_18_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>


            </lv_label>

            <lv_label text="&#x4EC5;&#x6062;&#x590D;&#x521D;&#x59CB;&#x8BBE;&#x7F6E;&#x53C2;&#x6570;" x="22" y="48" width="216">
                <style name="me106_text_14_gray_ba_center"/>
                <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>


            </lv_label>
            <lv_label text="&#x4E0D;&#x4F1A;&#x66F4;&#x65B0;&#x56FA;&#x4EF6;&#x6216;&#x7A0B;&#x5E8F;" x="22" y="70" width="216">
                <style name="me106_text_14_gray_ba_center"/>
                <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>


            </lv_label>

            <lv_button name="factory_cancel_btn" x="24" y="104" width="96" height="32" style_pad_all="0">
                <style name="me106_panel_blue_r6"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>


                <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="0"/>
                <lv_label text="&#x53D6;&#x6D88;" align="center" width="96">
                    <style name="me106_text_16_white_center"/>
                    <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <subject_set_int_event subject="meter_factory_confirm_index" value="0" trigger="clicked"/>
                <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="none"/>
            </lv_button>

            <lv_button name="factory_cancel_btn_inactive" x="24" y="104" width="96" height="32" style_bg_color="0x1F1F1F" style_bg_opa="255" style_border_width="0" style_radius="6" style_pad_all="0" style_shadow_width="0">


                <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="1"/>
                <lv_label text="&#x53D6;&#x6D88;" align="center" width="96">
                    <style name="me106_text_16_gray_ba_center"/>
                    <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>


                </lv_label>
                <subject_set_int_event subject="meter_factory_confirm_index" value="0" trigger="clicked"/>
            </lv_button>

            <lv_button name="factory_confirm_btn" x="140" y="104" width="96" height="32" style_pad_all="0">
                <style name="me106_panel_blue_r6"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>


                <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="1"/>
                <lv_label text="&#x6062;&#x590D;&#x8BBE;&#x7F6E;" align="center" width="96">
                    <style name="me106_text_16_white_center"/>
                    <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <subject_set_int_event subject="meter_factory_reset_request" value="1" trigger="clicked"/>
                <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="none"/>
            </lv_button>

            <lv_button name="factory_confirm_btn_inactive" x="140" y="104" width="96" height="32" style_bg_color="0x1F1F1F" style_bg_opa="255" style_border_width="0" style_radius="6" style_pad_all="0" style_shadow_width="0">


                <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="0"/>
                <lv_label text="&#x6062;&#x590D;&#x8BBE;&#x7F6E;" align="center" width="96">
                    <style name="me106_text_16_gray_ba_center"/>
                    <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>


                </lv_label>
                <subject_set_int_event subject="meter_factory_confirm_index" value="1" trigger="clicked"/>
            </lv_button>
        </lv_obj>

        <!-- 底部硬按键区：返回=取消，左右=切换选择，确认=执行当前弹窗按钮。 -->
        <lv_obj name="screen_settings_factory_bottom_bar" x="0" y="207" width="320" height="33" style_border_width="0" style_pad_all="0" scrollable="false">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>


        </lv_obj>

        <lv_button name="factory_btn_return" x="0" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>


            <lv_image src="meter_icon_return" align="center" style_transform_pivot_x="8" style_transform_pivot_y="7" style_transform_scale_x="230" style_transform_scale_y="230"/>
            <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="none"/>
        </lv_button>

        <lv_button name="factory_btn_left" x="80" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>


            <lv_image src="meter_arrow_left" align="center" y="0" style_transform_pivot_x="10" style_transform_pivot_y="14" style_transform_scale_x="120" style_transform_scale_y="120"/>
            <subject_increment_event subject="meter_factory_confirm_index" step="-1" min_value="0" max_value="1" rollover="true" trigger="clicked"/>
        </lv_button>

        <lv_button name="factory_btn_right" x="160" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>


            <lv_image src="meter_arrow_right" align="center" y="0" style_transform_pivot_x="10" style_transform_pivot_y="14" style_transform_scale_x="120" style_transform_scale_y="120"/>
            <subject_increment_event subject="meter_factory_confirm_index" step="1" min_value="0" max_value="1" rollover="true" trigger="clicked"/>
        </lv_button>

        <lv_button name="factory_btn_yes" x="240" y="207" width="80" height="32">
            <style name="me106_btn_flat_blue"/>
            <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>


            <lv_image src="meter_yes" align="center" style_transform_pivot_x="9" style_transform_pivot_y="6" style_transform_scale_x="230" style_transform_scale_y="230"/>
        </lv_button>

        <lv_button name="factory_btn_yes_cancel" x="240" y="207" width="80" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="0"/>
            <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="none"/>
        </lv_button>

        <lv_button name="factory_btn_yes_confirm" x="240" y="207" width="80" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_factory_confirm_index" flag="hidden" ref_value="1"/>
            <subject_set_int_event subject="meter_factory_reset_request" value="1" trigger="clicked"/>
            <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="none"/>
        </lv_button>
    </view>
</screen>
