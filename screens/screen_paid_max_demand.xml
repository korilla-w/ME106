<screen>
    <animations>
        <timeline name="content_open">
            <animation target="page_content" prop="opa" start="0" end="255" duration="110" early_apply="true"/>
            <animation target="page_content" prop="translate_y" start="4" end="0" duration="110" early_apply="true"/>
        </timeline>
    </animations>
    <view width="320" height="240">
        <style name="me106_fill_black"/>
        <bind_style name="me106_theme_light_screen_bg" subject="meter_theme_index" ref_value="1"/>
        <bind_style name="me106_theme_alarm_screen_bg" subject="meter_theme_index" ref_value="2"/>
        <play_timeline_event target="self" timeline="content_open" trigger="screen_loaded"/>
        <subject_set_int_event subject="meter_paid_contact_popup" value="0" trigger="screen_loaded"/>

        <!-- UI分组：付费提示页只表达最大需量开通状态，不接入需量计算逻辑。 -->
        <lv_obj name="page_content" x="0" y="0" width="320" height="207" style_bg_opa="0" style_border_width="0" style_pad_all="0" scrollable="false">
            <lv_label text="&#x6700;&#x5927;&#x9700;&#x91CF;" x="170" y="17" width="126">
                <style name="me106_text_16_white_right"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>

            <lv_obj name="paid_max_demand_icon_halo" x="130" y="48" width="60" height="60" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_gray24_r8"/>
                <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                <lv_image src="meter_icon_electric_energy" align="center" style_transform_pivot_x="16" style_transform_pivot_y="16" style_transform_scale_x="150" style_transform_scale_y="150">
                    <style name="me106_icon_cyan"/>
                </lv_image>
            </lv_obj>

            <lv_label text="&#x4ED8;&#x8D39;&#x529F;&#x80FD;" x="80" y="119" width="160">
                <style name="me106_text_18_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <lv_label text="&#x9700;&#x8981;&#x4ED8;&#x8D39;&#x5347;&#x7EA7;&#x540E;&#x4F7F;&#x7528;" x="50" y="148" width="220">
                <style name="me106_text_16_gray_ba_center"/>
                <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <lv_label text="&#x8BF7;&#x8054;&#x7CFB;&#x670D;&#x52A1;&#x5546;&#x5F00;&#x901A;" x="70" y="174" width="180">
                <style name="me106_text_14_gray_ba_center"/>
                <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>
            </lv_label>

            <!-- 联系弹窗：确认键只打开联系方式，不触发真实购买或授权流程。 -->
            <lv_obj name="paid_max_demand_contact_popup" x="34" y="31" width="252" height="162" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_gray24_r8"/>
                <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                <bind_flag_if_not_eq subject="meter_paid_contact_popup" flag="hidden" ref_value="1"/>
                <lv_label text="&#x5347;&#x7EA7;&#x8054;&#x7CFB;&#x65B9;&#x5F0F;" x="18" y="14" width="132">
                    <style name="me106_text_16_white"/>
                    <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <lv_image src="meter_power_quality_qr" x="18" y="44" width="92" height="92"/>
                <lv_label text="&#x626B;&#x7801;&#x5F00;&#x901A;" x="126" y="48" width="96">
                    <style name="me106_text_16_white"/>
                    <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <lv_label text="&#x738B;&#x5DE5;&#xFF1A;13328775236" x="126" y="76" width="112">
                    <style name="me106_text_14_gray_ba"/>
                    <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <lv_label text="&#x8FD4;&#x56DE;&#x952E;&#x5173;&#x95ED;" x="126" y="105" width="104">
                    <style name="me106_text_14_gray_ba"/>
                    <bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/>
                    <bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/>
                </lv_label>
                <lv_button name="paid_max_demand_popup_close" x="212" y="8" width="30" height="30" style_bg_opa="0" style_border_width="0" style_shadow_width="0" style_pad_all="0">
                    <lv_label text="X" align="center" width="30"><style name="me106_text_14_gray_ba_center"/><bind_style name="me106_theme_light_muted" subject="meter_theme_index" ref_value="1"/><bind_style name="me106_theme_alarm_muted" subject="meter_theme_index" ref_value="2"/></lv_label>
                    <subject_set_int_event subject="meter_paid_contact_popup" value="0" trigger="clicked"/>
                </lv_button>
            </lv_obj>
        </lv_obj>

        <!-- UI分组：沿用原最大需量页的底部导航关系，只替换中间功能内容。 -->
        <lv_obj name="screen_paid_max_demand_bottom_bar" x="0" y="207" width="320" height="33" style_border_width="0" style_pad_all="0" scrollable="false">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
        </lv_obj>
        <lv_button name="paid_max_demand_btn_settings" x="0" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <style name="me106_btn_flat_blue"/>
            <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
            <bind_flag_if_eq subject="meter_paid_contact_popup" flag="hidden" ref_value="1"/>
            <lv_image src="meter_setting" align="center" x="0" y="0" style_transform_pivot_x="16" style_transform_pivot_y="16" style_transform_scale_x="110" style_transform_scale_y="110"/>
            <lv_obj-screen_create_event screen="screen_settings" trigger="clicked" anim_type="fade_in" duration="120"/>
        </lv_button>
        <lv_button name="paid_max_demand_btn_close_popup" x="0" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <bind_flag_if_not_eq subject="meter_paid_contact_popup" flag="hidden" ref_value="1"/>
            <lv_image src="meter_icon_return" align="center" style_transform_pivot_x="8" style_transform_pivot_y="7" style_transform_scale_x="230" style_transform_scale_y="230"/>
            <subject_set_int_event subject="meter_paid_contact_popup" value="0" trigger="clicked"/>
        </lv_button>
        <lv_button name="paid_max_demand_btn_menu" x="80" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_menu" align="center" x="0" y="0" style_transform_pivot_x="12" style_transform_pivot_y="12" style_transform_scale_x="150" style_transform_scale_y="150"/>
            <lv_obj-screen_create_event screen="screen_function_menu" trigger="clicked" anim_type="fade_in" duration="120"/>
        </lv_button>
        <lv_button name="paid_max_demand_btn_prev" x="160" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_arrow_left" align="center" y="0" style_transform_pivot_x="10" style_transform_pivot_y="14" style_transform_scale_x="120" style_transform_scale_y="120"/>
            <lv_obj-screen_create_event screen="screen_phase_frequency" trigger="clicked" anim_type="none"/>
        </lv_button>
        <lv_button name="paid_max_demand_btn_next" x="240" y="207" width="80" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_icon_select" align="center"/>
            <subject_set_int_event subject="meter_paid_contact_popup" value="1" trigger="clicked"/>
        </lv_button>
    </view>
</screen>
