<screen>

    <view width="320" height="240">
        <style name="me106_fill_gray1f"/>
        <bind_style name="me106_theme_light_screen_bg" subject="meter_theme_index" ref_value="1"/>
        <bind_style name="me106_theme_alarm_screen_bg" subject="meter_theme_index" ref_value="2"/>
        <subject_set_int_event subject="meter_ratio_digit_selected_index" value="0" trigger="screen_loaded"/>

        <!-- UI分组：页面内容区。这里只放视觉控件，设置生效留给逻辑/执行层处理。 -->
        <lv_obj name="page_content" x="0" y="0" width="320" height="207" style_bg_opa="0" style_border_width="0" style_pad_all="0" scrollable="false">
        <lv_label text="PT&#x53D8;&#x6BD4;" x="152" y="17" width="144">
            <style name="me106_text_16_white_right"/>
            <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
        </lv_label>

        <lv_button name="pt_ratio_digit_0" x="40" y="90" width="48" height="60" style_pad_all="0">
            <style name="me106_panel_gray24_r8"/>
            <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                        <lv_obj name="pt_ratio_digit_0_selected_bg" x="0" y="0" width="48" height="60" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_blue_r8"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
                <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="0"/>
            </lv_obj>
            <lv_label bind_text="meter_pt_ratio_digit_0" bind_text-fmt="%d" align="center" width="48">
                <style name="me106_text_36_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <subject_set_int_event subject="meter_ratio_digit_selected_index" value="0" trigger="clicked"/>
        </lv_button>

        <lv_button name="pt_ratio_digit_1" x="104" y="90" width="48" height="60" style_pad_all="0">
            <style name="me106_panel_gray24_r8"/>
            <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                        <lv_obj name="pt_ratio_digit_1_selected_bg" x="0" y="0" width="48" height="60" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_blue_r8"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
                <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="1"/>
            </lv_obj>
            <lv_label bind_text="meter_pt_ratio_digit_1" bind_text-fmt="%d" align="center" width="48">
                <style name="me106_text_36_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <subject_set_int_event subject="meter_ratio_digit_selected_index" value="1" trigger="clicked"/>
        </lv_button>

        <lv_button name="pt_ratio_digit_2" x="168" y="90" width="48" height="60" style_pad_all="0">
            <style name="me106_panel_gray24_r8"/>
            <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                        <lv_obj name="pt_ratio_digit_2_selected_bg" x="0" y="0" width="48" height="60" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_blue_r8"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
                <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="2"/>
            </lv_obj>
            <lv_label bind_text="meter_pt_ratio_digit_2" bind_text-fmt="%d" align="center" width="48">
                <style name="me106_text_36_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <subject_set_int_event subject="meter_ratio_digit_selected_index" value="2" trigger="clicked"/>
        </lv_button>

        <lv_button name="pt_ratio_digit_3" x="232" y="90" width="48" height="60" style_pad_all="0">
            <style name="me106_panel_gray24_r8"/>
            <bind_style name="me106_theme_light_panel" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_panel" subject="meter_theme_index" ref_value="2"/>
                        <lv_obj name="pt_ratio_digit_3_selected_bg" x="0" y="0" width="48" height="60" style_pad_all="0" style_border_width="0" scrollable="false">
                <style name="me106_panel_blue_r8"/>
                <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
                <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="3"/>
            </lv_obj>
            <lv_label bind_text="meter_pt_ratio_digit_3" bind_text-fmt="%d" align="center" width="48">
                <style name="me106_text_36_white_center"/>
                <bind_style name="me106_theme_light_text" subject="meter_theme_index" ref_value="1"/>
                <bind_style name="me106_theme_alarm_text" subject="meter_theme_index" ref_value="2"/>
            </lv_label>
            <subject_set_int_event subject="meter_ratio_digit_selected_index" value="3" trigger="clicked"/>
        </lv_button>

        </lv_obj>

        <!-- UI分组：底部硬按键区。按钮只发出导航/选择意图，不直接处理硬件。 -->
        <lv_obj name="screen_settings_ratio_pt_bottom_bar" x="0" y="207" width="320" height="33" style_border_width="0" style_pad_all="0" scrollable="false">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
        </lv_obj>
        <lv_button name="pt_ratio_btn_return" x="0" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_icon_return" align="center" style_transform_pivot_x="8" style_transform_pivot_y="7" style_transform_scale_x="230" style_transform_scale_y="230"/>
            <lv_obj-screen_create_event screen="screen_settings_ratio" trigger="clicked" anim_type="none"/>
        </lv_button>

        <lv_button name="pt_ratio_btn_digit" x="80" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_arrow_up" align="center" style_transform_pivot_x="7" style_transform_pivot_y="5" style_transform_scale_x="230" style_transform_scale_y="230"/>
        </lv_button>

        <lv_button name="pt_ratio_btn_value" x="160" y="207" width="79" height="32">
            <style name="me106_btn_flat_gray47"/>
            <bind_style name="me106_theme_light_nav" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_nav" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_arrow_right" align="center" style_transform_pivot_x="10" style_transform_pivot_y="14" style_transform_scale_x="120" style_transform_scale_y="120"/>
            <subject_increment_event subject="meter_ratio_digit_selected_index" step="1" min_value="0" max_value="3" rollover="true" trigger="clicked"/>
        </lv_button>

        <lv_button name="pt_ratio_btn_yes" x="240" y="207" width="80" height="32">
            <style name="me106_btn_flat_blue"/>
            <bind_style name="me106_theme_light_accent" subject="meter_theme_index" ref_value="1"/>
            <bind_style name="me106_theme_alarm_accent" subject="meter_theme_index" ref_value="2"/>
            <lv_image src="meter_yes" align="center" style_transform_pivot_x="9" style_transform_pivot_y="6" style_transform_scale_x="230" style_transform_scale_y="230"/>
            <lv_obj-screen_create_event screen="screen_settings_ratio" trigger="clicked" anim_type="none"/>
        </lv_button>

        <lv_button name="pt_ratio_btn_value_0" x="80" y="207" width="79" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="0"/>
            <subject_increment_event subject="meter_pt_ratio_digit_0" step="1" min_value="0" max_value="9" rollover="true" trigger="clicked"/>
        </lv_button>
        <lv_button name="pt_ratio_btn_value_1" x="80" y="207" width="79" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="1"/>
            <subject_increment_event subject="meter_pt_ratio_digit_1" step="1" min_value="0" max_value="9" rollover="true" trigger="clicked"/>
        </lv_button>
        <lv_button name="pt_ratio_btn_value_2" x="80" y="207" width="79" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="2"/>
            <subject_increment_event subject="meter_pt_ratio_digit_2" step="1" min_value="0" max_value="9" rollover="true" trigger="clicked"/>
        </lv_button>
        <lv_button name="pt_ratio_btn_value_3" x="80" y="207" width="79" height="32" style_bg_opa="0" style_border_width="0" style_shadow_width="0">
            <bind_flag_if_not_eq subject="meter_ratio_digit_selected_index" flag="hidden" ref_value="3"/>
            <subject_increment_event subject="meter_pt_ratio_digit_3" step="1" min_value="0" max_value="9" rollover="true" trigger="clicked"/>
        </lv_button>
    </view>
</screen>
